<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect root to public/index.php directly to avoid directory redirect
    RewriteRule ^$ public/index.php [L]

    # Rewrite non-existent files/folders to public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
